#!/usr/bin/env bash
set -euo pipefail

WIDGET_DIR="${FONDO_WIDGET_DIR:-$HOME/.local/share/fondo/widgets}"
DURATION="${FONDO_WIDGET_DURATION:-18}"

if [[ ! -d "$WIDGET_DIR" ]]; then
  echo "Widget dir missing: $WIDGET_DIR"
  exit 1
fi

list_available() {
  local w
  for w in "$WIDGET_DIR"/*; do
    [[ -x "$w" ]] || continue
    "$w" --check >/dev/null 2>&1 && basename "$w"
  done
}

if [[ "${1:-}" == "--list" ]]; then
  list_available | sort
  exit 0
fi

mapfile -t widgets < <(list_available)
if [[ "${#widgets[@]}" -eq 0 ]]; then
  echo "No available hollywood-style widgets (missing dependencies)."
  echo "Tip: install extras like apg, atop, bmon, ccze, jp2a, speedometer, mplayer"
  exit 1
fi

has_widget_name() {
  local target="$1"
  local w
  for w in "${widgets[@]}"; do
    [[ "$w" == "$target" ]] && return 0
  done
  return 1
}

map_ok() {
  local cols lines
  cols=$(tput cols 2>/dev/null || echo 80)
  lines=$(tput lines 2>/dev/null || echo 24)
  local min_cols="${FONDO_MAP_MIN_COLS:-68}"
  local min_lines="${FONDO_MAP_MIN_LINES:-16}"
  (( cols >= min_cols && lines >= min_lines ))
}

mplayer_ok() {
  local cols lines
  cols=$(tput cols 2>/dev/null || echo 80)
  lines=$(tput lines 2>/dev/null || echo 24)
  local min_cols="${FONDO_MPLAYER_MIN_COLS:-88}"
  local min_lines="${FONDO_MPLAYER_MIN_LINES:-22}"
  (( cols >= min_cols && lines >= min_lines ))
}

pick_random_widget() {
  local candidate tries alt

  for tries in {1..24}; do
    candidate="${widgets[RANDOM % ${#widgets[@]}]}"

    if [[ "$candidate" == "map" ]] && ! map_ok; then
      continue
    fi

    if [[ "$candidate" == "mplayer" ]]; then
      if ! mplayer_ok; then
        continue
      fi
      if (( RANDOM % 1000 < 995 )); then
        continue
      fi
    fi

    echo "$candidate"
    return 0
  done

  for alt in "${widgets[@]}"; do
    if [[ "$alt" == "map" ]] && ! map_ok; then
      continue
    fi
    if [[ "$alt" == "mplayer" ]]; then
      continue
    fi
    echo "$alt"
    return 0
  done

  echo "${widgets[0]}"
}

iter=0
last_map_iter=0
while true; do
  iter=$((iter + 1))

  if has_widget_name "map" && map_ok && (( iter - last_map_iter >= 4 )) && (( iter % 5 == 0 || RANDOM % 100 < 22 )); then
    pick="map"
  else
    pick="$(pick_random_widget)"
  fi

  if [[ "$pick" == "map" ]]; then
    last_map_iter=$iter
  fi

  run_duration="$DURATION"
  [[ "$pick" == "mplayer" ]] && run_duration="${FONDO_MPLAYER_MAX_SECS:-4}"
  [[ "$pick" == "map" ]] && run_duration="${FONDO_MAP_WIDGET_SECS:-11}"
  [[ "$pick" == "asciiquarium" ]] && run_duration="${FONDO_ASCIQUIARIUM_MAX_SECS:-16}"

  printf '\033[1;96m[%s]\033[0m widget: \033[1;92m%s\033[0m\n\n' "$(date +%H:%M:%S)" "$pick"
  if command -v timeout >/dev/null 2>&1; then
    timeout --foreground "$run_duration" "$WIDGET_DIR/$pick" || true
  else
    "$WIDGET_DIR/$pick" || true
  fi
  clear
done
